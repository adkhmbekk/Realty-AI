@echo off
chcp 65001 >nul
cd /d "%~dp0"
title Realty AI - обновление (выкатка)

echo ============================================
echo            Realty AI - ОБНОВЛЕНИЕ
echo ============================================
echo.
echo Эта кнопка делает три вещи одна за другой:
echo   1) скачивает свежий код с GitHub;
echo   2) пересобирает проект;
echo   3) перезапускает его.
echo Ничего больше нажимать не нужно - просто дождись надписи "Готово".
echo.

REM ── Шаг 0. Проверяем, что нужные программы на месте ──────────────────────
where git >nul 2>&1
if errorlevel 1 (
  echo [!] На этом компьютере не установлен Git, без него скачать код нельзя.
  echo     Установи его один раз отсюда: https://git-scm.com/download/win
  echo     (просто соглашайся со всем по умолчанию), затем запусти update.bat снова.
  echo.
  pause
  exit /b 1
)

docker info >nul 2>&1
if errorlevel 1 (
  echo [!] Docker не запущен.
  echo     Открой Docker Desktop, дождись зелёного значка и запусти этот файл снова.
  echo.
  pause
  exit /b 1
)

if not exist ".env" (
  echo [!] Не найден файл .env с секретами - без него туннель ngrok не поднимется.
  echo     Скопируй .env.example в .env и впиши NGROK_AUTHTOKEN (см. .env.example).
  echo.
  pause
  exit /b 1
)

REM ── Шаг 1. Скачиваем свежий код с GitHub ────────────────────────────────
echo [1/3] Скачиваю свежий код с GitHub...
echo.
git pull --ff-only
if errorlevel 1 (
  echo.
  echo [!] Не получилось чисто скачать обновление.
  echo     Скорее всего, на этом компьютере есть ручные правки кода, которые
  echo     мешают обновлению. САМ это не чини - сделай скриншот этого окна и
  echo     пришли разработчику. Проект продолжает работать на старой версии,
  echo     ничего не сломалось.
  echo.
  pause
  exit /b 1
)

REM ── Шаг 2 и 3. Пересобираем и перезапускаем ─────────────────────────────
echo.
echo [2/3] Пересобираю проект с новым кодом... (может занять пару минут)
echo.
docker compose up -d --build
if errorlevel 1 (
  echo.
  echo [!] Ошибка при пересборке. Прокрути сообщения выше и пришли их разработчику.
  echo     Если что, вернуть всё как было поможет rebuild.bat.
  echo.
  pause
  exit /b 1
)

echo.
echo [3/3] Перезапуск завершён.
echo.
echo ============================================
echo   Готово! Проект обновлён и снова работает.
echo ============================================
echo.
echo   Публичная ссылка (не меняется):
echo     https://pagan-crawling-retiring.ngrok-free.dev
echo.
echo   Локально на этом компьютере:
echo     Приложение:    http://localhost:8080
echo     Панель ngrok:  http://localhost:4040
echo.
echo   Если что-то выглядит не так - посмотри логи кнопкой logs.bat.
echo.
pause
