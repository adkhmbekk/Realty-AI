# Caddy отдаёт собранное React-приложение из /srv и проксирует API на backend.
# Страница и её запросы к API живут на одном адресе — без CORS-сложностей.

{
	# H1 (ревью): плейсхолдер {client_ip} разворачивает X-Forwarded-For, ДОВЕРЯЯ
	# только внутренним хопам (туннели ngrok/tailscale в Docker-сети — приватные
	# IP). Задаётся ГЛОБАЛЬНО (в servers), иначе {client_ip} = адрес соединения.
	servers {
		trusted_proxies static private_ranges
	}
}

:80 {
	encode gzip

	# ─── Заголовки безопасности (применяются ко всем ответам) ───────────────
	header {
		# Не раскрываем сервер.
		-Server
		# Заставляем HTTPS на год (туннель отдаёт HTTPS).
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Запрет «угадывания» типа содержимого (защита от MIME-sniffing).
		X-Content-Type-Options "nosniff"
		# Меньше утечки реферера на сторонние ресурсы.
		Referrer-Policy "strict-origin-when-cross-origin"
		# Ограничиваем доступ к мощным API браузера.
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# CSP: какие источники разрешены. Mini App грузит официальный скрипт
		# Telegram (telegram.org), остальное — только со своего origin.
		# frame-ancestors разрешает встраивание лишь в клиентах Telegram
		# (защита от clickjacking). object-src/base-uri закрыты.
		Content-Security-Policy "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors https://*.telegram.org https://telegram.org; script-src 'self' https://telegram.org; connect-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; form-action 'self'"
	}

	# Наружу проксируем только рабочее API и проверку здоровья.
	# Интерактивная документация (/docs, /openapi.json) НЕ выставляется в интернет
	# и по умолчанию отключена в самом backend (ENABLE_DOCS=false).
	@backend path /api/* /health
	handle @backend {
		# Ограничение размера тела запроса (защита от DoS большими телами).
		request_body {
			max_size 25MB
		}
		reverse_proxy backend:8000 {
			# H1 (ревью): доверяем X-Forwarded-For только от внутренних адресов
			# (туннели ngrok/tailscale в Docker-сети — приватные IP). По ним Caddy
			# вычисляет НАСТОЯЩИЙ IP клиента ({client_ip}) и кладёт его в заголовок,
			# который backend читает напрямую. Клиент подделать не может: header_up
			# ПЕРЕЗАПИСЫВАЕт значение. Без этого rate-limit/аудит шли по одному IP
			# туннеля на всех (глобальный лимит = дешёвый DoS входа).
			trusted_proxies private_ranges
			header_up X-Real-Client {client_ip}
		}
		# ВРЕМЕННО (H1-диагностика): эхо вычисленного IP в ответ. Удалить после проверки.
		header X-Client-Debug {client_ip}
	}

	# Остальное — статика SPA. Любой путь отдаёт index.html (клиентская навигация).
	handle {
		root * /srv

		# Хэшированные файлы (их имя меняется при каждой сборке) можно кэшировать
		# надолго. А вот index.html и прочее — НЕ кэшировать, иначе Telegram/браузер
		# показывает старую версию приложения после обновления.
		@assets path /assets/*
		@notassets not path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"
		header @notassets Cache-Control "no-store"

		try_files {path} /index.html
		file_server
	}
}
