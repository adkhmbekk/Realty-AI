# Caddy отдаёт собранное React-приложение из /srv и проксирует API на backend.
# Страница и её запросы к API живут на одном адресе — без CORS-сложностей.

:80 {
	encode gzip

	# Наружу проксируем только рабочее API и проверку здоровья.
	# Интерактивная документация (/docs, /openapi.json) НЕ выставляется в интернет —
	# она остаётся доступной только локально на http://localhost:8000/docs.
	@backend path /api/* /health
	handle @backend {
		reverse_proxy backend:8000
	}

	# Остальное — статика SPA. Любой путь отдаёт index.html (клиентская навигация).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
