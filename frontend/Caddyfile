# Caddy отдаёт собранное React-приложение из /srv и проксирует API на backend.
# Страница и её запросы к API живут на одном адресе — без CORS-сложностей.

:80 {
	encode gzip

	# Всё, что начинается с /api/, а также /health и документация — на backend.
	@backend path /api/* /health /docs /docs/* /openapi.json
	handle @backend {
		reverse_proxy backend:8000
	}

	# Остальное — статика SPA. Любой путь отдаёт index.html (клиентская навигация).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
