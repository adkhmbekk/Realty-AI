# Пример файла настроек. Скопируй его в файл с именем .env и заполни значения.
# Файл .env НЕ попадает в репозиторий (он в .gitignore) — там хранятся секреты.

# ─── База данных ─────────────────────────────────────────────────────────
# Для локального запуска через docker-compose менять НЕ нужно — строка
# DATABASE_URL собирается там из POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB
# (см. корневой .env). Значение ниже нужно, только если запускаешь backend
# без Docker. ВАЖНО: используй надёжный случайный пароль, а не плейсхолдер.
# DATABASE_URL=postgresql+psycopg://realty:ЗАМЕНИ_НА_СЛУЧАЙНЫЙ_ПАРОЛЬ@localhost:5432/realty

# ─── Telegram / Безопасность ─────────────────────────────────────────────
# Токен бота от @BotFather (нужен для входа через Telegram).
BOT_TOKEN=

# Твой личный Telegram ID — этот человек станет суперадмином платформы.
# Узнать свой ID можно, написав боту @userinfobot в Telegram.
SUPERADMIN_TELEGRAM_ID=

# Секрет для подписи пропусков (любая длинная случайная строка).
# Можно оставить пустым: тогда секрет сгенерируется автоматически ОДИН РАЗ
# и сохранится в ОТДЕЛЬНОМ томе секретов (SECRET_DIR, по умолчанию /secrets) —
# он переживёт перезапуски, но НЕ лежит рядом с фото и НЕ попадает в бэкапы.
# Задай своё значение, если разворачиваешь проект на нескольких серверах.
JWT_SECRET=

# Папка для секретов приложения (отдельный том). Менять обычно не нужно.
# SECRET_DIR=/secrets

# Максимальный «возраст» данных входа Telegram в секундах (по умолчанию 3600).
# Чем меньше — тем у́же окно для повторного использования перехваченного входа.
# INIT_DATA_MAX_AGE_SECONDS=3600

# Показывать ли /docs и /openapi.json. По умолчанию false (безопасно).
# ENABLE_DOCS=false


# Имя бота без @ (например my_realty_bot). Нужно только для красивой
# ссылки-приглашения сотрудников. Если оставить пустым — код приглашения
# можно будет передать вручную.
BOT_USERNAME=
