# Пример файла настроек для запуска через docker-compose.
# Скопируй этот файл в файл с именем .env (рядом с docker-compose.yml) и заполни.
# Файл .env НЕ попадает в репозиторий (он в .gitignore) — там твои секреты.
#
# На шаге 1C-1 этот файл НЕ нужен. Он понадобится на шаге 1C-2,
# когда будем подключать вход через Telegram.

# ─── База данных (ОБЯЗАТЕЛЬНО) ──────────────────────────────────────────
# Пароль PostgreSQL. ОБЯЗАТЕЛЬНО задай надёжный СЛУЧАЙНЫЙ пароль — без него
# запуск остановится. Раньше пароль был «зашит» в docker-compose.yml и был
# одинаковым у всех; теперь он берётся только отсюда и наружу база не светится.
# Сгенерировать можно командой:  openssl rand -base64 24
POSTGRES_PASSWORD=
# Можно изменить имя пользователя/базы (необязательно).
POSTGRES_USER=realty
POSTGRES_DB=realty

# Токен бота от @BotFather.
BOT_TOKEN=

# Твой личный Telegram ID (узнать: напиши боту @userinfobot в Telegram).
# Этот человек станет суперадмином платформы.
SUPERADMIN_TELEGRAM_ID=

# Секрет для подписи пропусков (JWT). Можно оставить пустым — тогда он
# сгенерируется сам и сохранится в ОТДЕЛЬНОМ томе секретов (не в папке фото и
# не в бэкапах). Для нескольких серверов задай одинаковое значение явно.
# Сгенерировать:  openssl rand -base64 48
JWT_SECRET=

# Показывать ли интерактивную документацию API (/docs). По умолчанию false
# (безопасно). Включай true только для локальной разработки.
ENABLE_DOCS=false


# Имя бота без @ (например my_realty_bot). Нужно только для красивой
# ссылки-приглашения сотрудников. Если оставить пустым — код приглашения
# можно будет передать вручную.
BOT_USERNAME=


# ─── Туннель ngrok (ОБЯЗАТЕЛЬНО) ────────────────────────────────────────
# Токен ngrok — это СЕКРЕТ. Раньше он был вшит в docker-compose.yml; теперь
# он хранится только здесь, в .env (этот файл НЕ попадает в репозиторий).
#
# Где взять токен: зайди на https://dashboard.ngrok.com → Your Authtoken →
# скопируй строку и вставь сюда после знака «=».
#
# ВАЖНО: старый токен уже «засветился» в истории git, поэтому в кабинете ngrok
# его нужно ОБНОВИТЬ (Reset/Regenerate authtoken) и вписать сюда новый.
NGROK_AUTHTOKEN=

# Домен ngrok. Можно оставить пустым — тогда подставится постоянный адрес
# проекта (pagan-crawling-retiring.ngrok-free.dev). Заполняй, только если
# используешь свой домен ngrok.
NGROK_DOMAIN=


# ─── Авто-бэкапы и подписка (НЕОБЯЗАТЕЛЬНО) ──────────────────────────────
# Авто-бэкапы делаются сами (сервис backup в docker-compose) и складываются в
# папку backups\. Эти настройки можно не трогать — у них есть значения по
# умолчанию.
#
# Как часто делать авто-копию (в часах) и сколько последних копий хранить:
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=7

# За сколько дней до окончания подписки бот заранее предупредит владельца
# агентства. 0 — отключить предупреждения. (Нужен заданный BOT_TOKEN.)
SUBSCRIPTION_WARN_DAYS=3


# Слать ли тебе (суперадмину) уведомление в бот о сбоях сервера (ошибки 500).
# true — включено (рекомендуется), false — выключить. Нужны BOT_TOKEN и
# SUPERADMIN_TELEGRAM_ID.
ERROR_ALERTS_ENABLED=true
