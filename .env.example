# Пример файла настроек для запуска через docker-compose.
# Скопируй этот файл в файл с именем .env (рядом с docker-compose.yml) и заполни.
# Файл .env НЕ попадает в репозиторий (он в .gitignore) — там твои секреты.

# Токен бота от @BotFather.
BOT_TOKEN=

# Твой личный Telegram ID (узнать: напиши боту @userinfobot в Telegram).
# Этот человек станет суперадмином платформы.
SUPERADMIN_TELEGRAM_ID=

# Секрет для подписи пропусков. Можно оставить пустым — сгенерируется сам.
JWT_SECRET=

# Имя бота без @ (например my_realty_bot). Нужно для ссылки-приглашения.
BOT_USERNAME=

# ─── ngrok: постоянный публичный адрес для Telegram Mini App ─────────────
# Регистрируешься на ngrok.com (бесплатно), затем:
#   1) NGROK_AUTHTOKEN — раздел "Your Authtoken" в кабинете ngrok.
#   2) NGROK_DOMAIN    — раздел "Domains" -> создать бесплатный домен
#      (вид: cool-name-1234.ngrok-free.app). Сюда вписать БЕЗ https://
# Этот адрес не меняется — вставь https://<NGROK_DOMAIN> в @BotFather один раз.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
