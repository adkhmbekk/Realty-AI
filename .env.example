# Пример файла настроек для запуска через docker-compose.
# Скопируй этот файл в файл с именем .env (рядом с docker-compose.yml) и заполни.
# Файл .env НЕ попадает в репозиторий (он в .gitignore) — там твои секреты.
#
# На шаге 1C-1 этот файл НЕ нужен. Он понадобится на шаге 1C-2,
# когда будем подключать вход через Telegram.

# Токен бота от @BotFather.
BOT_TOKEN=

# Твой личный Telegram ID (узнать: напиши боту @userinfobot в Telegram).
# Этот человек станет суперадмином платформы.
SUPERADMIN_TELEGRAM_ID=

# Секрет для подписи пропусков. Можно оставить пустым — сгенерируется сам.
JWT_SECRET=


# Имя бота без @ (например my_realty_bot). Нужно только для красивой
# ссылки-приглашения сотрудников. Если оставить пустым — код приглашения
# можно будет передать вручную.
BOT_USERNAME=


# ─── Туннель ngrok (ОБЯЗАТЕЛЬНО) ────────────────────────────────────────
# Токен ngrok — это СЕКРЕТ. Раньше он был вшит в docker-compose.yml; теперь
# он хранится только здесь, в .env (этот файл НЕ попадает в репозиторий).
#
# Где взять токен: зайди на https://dashboard.ngrok.com → Your Authtoken →
# скопируй строку и вставь сюда после знака «=».
#
# ВАЖНО: старый токен уже «засветился» в истории git, поэтому в кабинете ngrok
# его нужно ОБНОВИТЬ (Reset/Regenerate authtoken) и вписать сюда новый.
NGROK_AUTHTOKEN=

# Домен ngrok. Можно оставить пустым — тогда подставится постоянный адрес
# проекта (pagan-crawling-retiring.ngrok-free.dev). Заполняй, только если
# используешь свой домен ngrok.
NGROK_DOMAIN=
